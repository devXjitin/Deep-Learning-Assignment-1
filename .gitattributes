# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Jupyter Notebooks
*.ipynb text eol=lf

# Data files
*.csv text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.pkl binary
*.pickle binary
*.h5 binary
*.hdf5 binary
*.weights binary
*.model binary
*.pt binary
*.pth binary
*.onnx binary
*.pb binary
*.tflite binary

# Notebook outputs - treat as binary to avoid merge conflicts
*.ipynb merge=nbconverter-driver
